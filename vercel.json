{
  "version": 2,
  "redirects": [
    {
      "source": "/",
      "missing": [
        {
          "type": "query",
          "key": "token",
          "value": "cartelflag"
        }
      ],
      "permanent": false,
      "destination": "https://t.me/cartel187"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
