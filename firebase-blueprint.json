{
  "entities": {
    "StalkerPlaylist": {
      "title": "Stalker Playlist",
      "description": "Definition of a Stalker IPTV playlist",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "logo": { "type": "string" },
        "enabled": { "type": "boolean" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "url", "userId"]
    }
  },
  "firestore": {
    "stalkerPlaylists/{playlistId}": {
      "schema": "StalkerPlaylist",
      "description": "Firestore collection for stalker playlists"
    }
  }
}
